# ── Polygon Bot Wallet ─────────────────────────────────────────────────────
# Generate with: python -c "from eth_account import Account; import secrets; pk='0x'+secrets.token_hex(32); a=Account.from_key(pk); print('POLYGON_PRIVATE_KEY='+pk); print('POLYGON_ADDRESS='+a.address)"
POLYGON_PRIVATE_KEY=0x_YOUR_PRIVATE_KEY_HERE
POLYGON_ADDRESS=0x_YOUR_ADDRESS_HERE

# ── Polymarket L2 API (generate with generate_keys.py after funding wallet) ─
POLY_API_KEY=
POLY_SECRET=
POLY_PASSPHRASE=

# ── Claude API ─────────────────────────────────────────────────────────────
# Get from: console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-

# ── Football Data APIs (all free signup) ───────────────────────────────────
# API-Football: rapidapi.com/api-sports/api/api-football (100 req/day free)
API_FOOTBALL_KEY=

# The Odds API: the-odds-api.com (500 req/month free)
ODDS_API_KEY=

# ── Risk Controls ──────────────────────────────────────────────────────────
MAX_BET_USD=10.0            # max dollars per single bet
MAX_DAILY_LOSS_USD=50.0     # circuit breaker: halt if daily loss exceeds this
MIN_LIQUIDITY_USD=500.0     # skip markets with less USDC liquidity
BETTING_INTERVAL_MINUTES=60 # how often to run one full improvement loop

# ── Monitoring (optional) ────────────────────────────────────────────────
ALERT_WEBHOOK_URL=           # Slack/Discord webhook for alerts (optional)
LOG_LEVEL=INFO               # DEBUG, INFO, WARNING, ERROR
